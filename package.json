{
  "name": "sompyler-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run --exclude 'src/conformance/**'",
    "test:conformance": "vitest --run src/conformance",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "fflate": "^0.8.3",
    "js-yaml": "^4.1.0",
    "solid-js": "^1.9.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.2.0"
  }
}
